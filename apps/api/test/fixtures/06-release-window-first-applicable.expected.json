          "object_values_contains": [
            "team:payments"
          ]
        }
      },
      "expected_matched_rules_contains": [
        "allow_release_manager_in_valid_window"
      ],
      "expected_trace_matched_rules_contains": [
        "allow_release_manager_in_valid_window"
      ],
      "expected_relation_inference": {
        "enabled": true,
        "applied": true,
        "reason": null
      },
      "expected_context_values": {
        "is_release_manager": true,
        "is_team_lead": false
      }
    },
    {
      "name": "release_manager_outside_validity_denied_by_fallback",
      "mode": "model_route",
