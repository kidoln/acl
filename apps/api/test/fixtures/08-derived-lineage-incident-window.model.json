{
  "model_meta": {
    "model_id": "tenant_orbit_kb_lineage_incident_window",
    "tenant_id": "tenant_orbit",
    "version": "2026.03.07",
    "status": "draft",
    "combining_algorithm": "ordered-deny-overrides"
  },
  "catalogs": {
    "action_catalog": ["read"],
    "subject_type_catalog": ["user", "department", "company"],
    "object_type_catalog": ["kb"],
    "subject_relation_type_catalog": [
      "belongs_to_department",
      "belongs_to_company"
    ],
    "object_relation_type_catalog": [
      "derives_to"
    ],
    "subject_object_relation_type_catalog": []
  },
  "relation_signature": {
    "subject_relations": [
      {
        "relation_type": "belongs_to_department",
        "from_types": ["user"],
        "to_types": ["department"]
      },
      {
        "relation_type": "belongs_to_company",
        "from_types": ["department"],
        "to_types": ["company"]
      }
    ],
    "object_relations": [
      {
        "relation_type": "derives_to",
        "from_types": ["kb"],
        "to_types": ["kb"]
      }
    ],
    "subject_object_relations": []
  },
  "object_onboarding": {
    "compatibility_mode": "compat_balanced",
    "default_profile": "minimal",
    "profiles": {
      "minimal": {
        "required_fields": ["tenant_id", "object_id", "object_type", "created_by"],
        "autofill": {
          "owner_ref": "created_by",
          "sensitivity": "normal"
        }
      }
    },
    "conditional_required": [
      {
        "when": "object.sensitivity == high",
        "add_fields": ["incident_level", "retention_class"]
      }
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "deny_read_when_incident_inactive_high",
        "subject_selector": "subject.type == user and context.incident_active == false",
        "object_selector": "object.type == kb and object.sensitivity == high",
        "action_set": ["read"],
        "effect": "deny",
        "priority": 300
      },
      {
        "id": "allow_read_same_company_lineage_incident_window",
        "subject_selector": "subject.type == user and context.same_company_via_lineage == true and context.incident_active == true",
        "object_selector": "object.type == kb and object.sensitivity == high",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 220,
        "validity": {
          "start": "2026-03-01T00:00:00.000Z",
          "end": "2026-03-31T23:59:59.000Z"
        }
      },
      {
        "id": "allow_read_normal_kb",
        "subject_selector": "subject.type == user",
        "object_selector": "object.type == kb and object.sensitivity == normal",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 100
      }
    ]
  },
  "constraints": {
    "sod_rules": [],
    "cardinality_rules": []
  },
  "lifecycle": {
    "event_rules": [
      {
        "event_type": "subject_removed",
        "handler": "revoke_direct_edges",
        "required": true
      },
      {
        "event_type": "object_derived",
        "handler": "refresh_lineage_cache",
        "required": false
      }
    ]
  },
  "consistency": {
    "default_level": "bounded_staleness",
    "high_risk_level": "strong",
    "bounded_staleness_ms": 2500
  },
  "quality_guardrails": {
    "attribute_quality": {
      "authority_whitelist": ["org_system", "lineage_service"],
      "freshness_ttl_sec": {
        "lineage_graph": 300,
        "org_membership": 900
      },
      "reject_unknown_source": true
    },
    "mandatory_obligations": []
  },
  "context_inference": {
    "enabled": true,
    "rules": [
      {
        "id": "infer_same_company_via_lineage",
        "output_field": "same_company_via_lineage",
        "subject_edges": [
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          },
          {
            "relation_type": "belongs_to_company",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "derives_to",
            "entity_side": "to",
            "max_depth": 3
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": false
      }
    ],
    "constraints": {
      "monotonic_only": true,
      "stratified_negation": false
    }
  }
}
