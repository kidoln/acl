  "policies": {
    "rules": [
      {
        "id": "allow_read_same_department_owner_resource",
        "subject_selector": "subject.type == user and context.same_department_direct == true",
        "object_selector": "object.type == kb",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 120
      },
      {
        "id": "allow_read_same_department_derived_resource",
        "subject_selector": "subject.type == user and context.same_department_via_derived_source == true",
        "object_selector": "object.type == kb and object.is_derived == true",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 110
      },
      {
        "id": "allow_read_same_virtual_team_owner_resource",
        "subject_selector": "subject.type == user and context.same_virtual_team_with_owner == true",
        "object_selector": "object.type == kb",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 100
      }
    ]
