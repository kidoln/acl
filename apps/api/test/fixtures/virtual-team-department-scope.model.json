    "mandatory_obligations": []
  },
  "context_inference": {
    "enabled": true,
    "rules": [
      {
        "id": "infer_same_department_direct",
        "output_field": "same_department_direct",
        "subject_edges": [
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "derives_to",
            "entity_side": "from"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": true
      },
      {
        "id": "infer_same_department_via_derived_source",
        "output_field": "same_department_via_derived_source",
        "subject_edges": [
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "derives_to",
            "entity_side": "to"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": false
      },
      {
        "id": "infer_same_virtual_team_with_owner",
        "output_field": "same_virtual_team_with_owner",
        "subject_edges": [
          {
            "relation_type": "member_of_virtual_team",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "derives_to",
            "entity_side": "from"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": true
      }
    ],
    "constraints": {
