{
  "model_meta": {
    "model_id": "tenant_acme_mixed_model_instance_visibility",
    "tenant_id": "tenant_acme",
    "version": "2026.03.06",
    "status": "draft",
    "combining_algorithm": "ordered-deny-overrides"
  },
  "catalogs": {
    "action_catalog": ["read"],
    "subject_type_catalog": ["user", "department", "company"],
    "object_type_catalog": ["kb"],
    "subject_relation_type_catalog": [
      "belongs_to_department",
      "belongs_to_company"
    ],
    "object_relation_type_catalog": [
      "derives_to"
    ],
    "subject_object_relation_type_catalog": []
  },
  "object_onboarding": {
    "compatibility_mode": "compat_balanced",
    "default_profile": "minimal",
    "profiles": {
      "minimal": {
        "required_fields": ["tenant_id", "object_id", "object_type", "created_by"],
        "autofill": {
          "owner_ref": "created_by",
          "sensitivity": "normal"
        }
      }
    },
    "conditional_required": []
  },
  "policies": {
    "rules": [
      {
        "id": "allow_read_by_input_attributes",
        "subject_selector": "subject.type == user and subject.department == rnd",
        "object_selector": "object.type == kb and object.department == rnd",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 300
      },
      {
        "id": "allow_read_same_company_from_control_plane_instance",
        "subject_selector": "subject.type == user and context.same_company == true",
        "object_selector": "object.type == kb",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 250
      },
      {
        "id": "deny_read_knowledge_base_1",
        "subject_selector": "subject.type == user",
        "object_selector": "object.id == kb:knowledge_1",
        "action_set": ["read"],
        "effect": "deny",
        "priority": 200
      },
      {
        "id": "allow_read_instance_override_alice_kb1",
        "subject_selector": "subject.id == user:alice",
        "object_selector": "object.id == kb:knowledge_1",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 1000
      }
    ]
  },
  "constraints": {
    "sod_rules": [],
    "cardinality_rules": []
  },
  "lifecycle": {
    "event_rules": [
      {
        "event_type": "subject_removed",
        "handler": "revoke_direct_edges",
        "required": true
      }
    ]
  },
  "consistency": {
    "default_level": "bounded_staleness",
    "high_risk_level": "strong",
    "bounded_staleness_ms": 3000
  },
  "quality_guardrails": {
    "attribute_quality": {
      "authority_whitelist": ["hr_system", "org_system"],
      "freshness_ttl_sec": {
        "org_membership": 900
      },
      "reject_unknown_source": true
    },
    "mandatory_obligations": []
  },
  "context_inference": {
    "enabled": true,
    "rules": [
      {
        "id": "infer_same_company",
        "output_field": "same_company",
        "subject_edges": [
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          },
          {
            "relation_type": "belongs_to_company",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "derives_to",
            "entity_side": "from"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": true
      }
    ],
    "constraints": {
      "monotonic_only": true,
      "stratified_negation": false
    }
  }
}
