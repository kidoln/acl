{
  "model_meta": {
    "model_id": "tenant_finbank_incident_response_access",
    "tenant_id": "tenant_finbank",
    "version": "2026.03.07",
    "status": "draft",
    "combining_algorithm": "deny-overrides"
  },
  "catalogs": {
    "action_catalog": ["read", "export"],
    "subject_type_catalog": ["user", "oncall_group", "department", "company"],
    "object_type_catalog": ["dataset"],
    "subject_relation_type_catalog": [
      "belongs_to_department",
      "belongs_to_company",
      "member_of_oncall",
      "oncall_group_for_department"
    ],
    "object_relation_type_catalog": [
      "owned_by"
    ],
    "subject_object_relation_type_catalog": [
      "belongs_to_department"
    ]
  },
  "relation_signature": {
    "subject_relations": [
      {
        "relation_type": "belongs_to_department",
        "from_types": ["user"],
        "to_types": ["department"]
      },
      {
        "relation_type": "belongs_to_company",
        "from_types": ["department"],
        "to_types": ["company"]
      },
      {
        "relation_type": "member_of_oncall",
        "from_types": ["user"],
        "to_types": ["oncall_group"]
      },
      {
        "relation_type": "oncall_group_for_department",
        "from_types": ["oncall_group"],
        "to_types": ["department"]
      }
    ],
    "object_relations": [
      {
        "relation_type": "owned_by",
        "from_types": ["dataset"],
        "to_types": ["dataset"]
      }
    ],
    "subject_object_relations": [
      {
        "relation_type": "belongs_to_department",
        "from_types": ["user"],
        "to_types": ["dataset"]
      }
    ]
  },
  "object_onboarding": {
    "compatibility_mode": "compat_balanced",
    "default_profile": "minimal",
    "profiles": {
      "minimal": {
        "required_fields": ["tenant_id", "object_id", "object_type", "created_by"],
        "autofill": {
          "owner_ref": "created_by",
          "sensitivity": "normal"
        }
      }
    },
    "conditional_required": [
      {
        "when": "object.sensitivity == high",
        "add_fields": ["data_domain", "retention_class"]
      }
    ]
  },
  "policies": {
    "rules": [
      {
        "id": "deny_export_high_sensitivity",
        "subject_selector": "subject.type == user",
        "object_selector": "object.type == dataset and object.sensitivity == high",
        "action_set": ["export"],
        "effect": "deny",
        "priority": 300
      },
      {
        "id": "allow_read_same_department_owner_resource",
        "subject_selector": "subject.type == user and context.same_department_owner == true",
        "object_selector": "object.type == dataset",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 140
      },
      {
        "id": "allow_read_oncall_department_resource",
        "subject_selector": "subject.type == user and context.oncall_department_match == true",
        "object_selector": "object.type == dataset",
        "action_set": ["read"],
        "effect": "allow",
        "priority": 130
      },
      {
        "id": "allow_export_oncall_low_sensitivity",
        "subject_selector": "subject.type == user and context.oncall_department_match == true",
        "object_selector": "object.type == dataset and object.sensitivity == normal",
        "action_set": ["export"],
        "effect": "allow",
        "priority": 120
      }
    ]
  },
  "constraints": {
    "sod_rules": [],
    "cardinality_rules": []
  },
  "lifecycle": {
    "event_rules": [
      {
        "event_type": "subject_removed",
        "handler": "revoke_direct_edges",
        "required": true
      },
      {
        "event_type": "incident_escalated",
        "handler": "sync_oncall_group_edges",
        "required": false
      }
    ]
  },
  "consistency": {
    "default_level": "bounded_staleness",
    "high_risk_level": "strong",
    "bounded_staleness_ms": 2000
  },
  "quality_guardrails": {
    "attribute_quality": {
      "authority_whitelist": ["hr_system", "incident_system"],
      "freshness_ttl_sec": {
        "department_membership": 900,
        "oncall_membership": 300
      },
      "reject_unknown_source": true
    },
    "mandatory_obligations": []
  },
  "context_inference": {
    "enabled": true,
    "rules": [
      {
        "id": "infer_same_department_owner",
        "output_field": "same_department_owner",
        "subject_edges": [
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "owned_by",
            "entity_side": "from"
          },
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": true
      },
      {
        "id": "infer_oncall_department_match",
        "output_field": "oncall_department_match",
        "subject_edges": [
          {
            "relation_type": "member_of_oncall",
            "entity_side": "from"
          },
          {
            "relation_type": "oncall_group_for_department",
            "entity_side": "from"
          }
        ],
        "object_edges": [
          {
            "relation_type": "owned_by",
            "entity_side": "from"
          },
          {
            "relation_type": "belongs_to_department",
            "entity_side": "from"
          }
        ],
        "object_owner_fallback": true,
        "owner_fallback_include_input": true
      }
    ],
    "constraints": {
      "monotonic_only": true,
      "stratified_negation": false
    }
  }
}
