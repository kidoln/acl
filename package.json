{
  "name": "enterprise-acl",
  "private": true,
  "version": "0.1.0",
  "description": "企业级通用ACL管理系统 Monorepo",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev": "turbo run dev --parallel",
    "dev:start": "bash ./scripts/start-dev.sh",
    "db:init:postgres": "pnpm --filter @acl/persistence run db:init:postgres"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "pnpm": "10.30.3",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}
